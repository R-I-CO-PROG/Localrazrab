# Database
DATABASE_URL=postgresql://suvenir:suvenir@localhost:5433/suvenir

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_HOST=0.0.0.0
UPLOADS_DIR=../../uploads
CORS_ORIGIN=http://localhost:3000

# Секрет между Web BFF и API (dev: можно не задавать; production: обязателен)
# Сгенерировать: openssl rand -hex 32
API_SECRET_KEY=

# Публичный URL API для референсов OpenRouter (лого/каталог).
# В production = URL вашего сайта (Next.js проксирует /uploads)
PUBLIC_API_URL=http://localhost:3001

# Frontend (apps/web/.env.local)
# Браузер ходит через BFF — не светим NestJS напрямую
NEXT_PUBLIC_API_BASE=/api/backend
SUVENIR_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_HOST=

# LLM: stub (default, без ключей) | openrouter | gemini | deepseek
LLM_PROVIDER=stub
LLM_FALLBACK_TO_STUB=true
LLM_RESPECT_USER_PRODUCTS=true
LLM_GENERATION_PROVIDER=stub
LLM_GENERATION_FALLBACK_CHAIN=
LLM_GENERATION_FALLBACK_LOCAL=true
OPENROUTER_API_KEY=
OPENROUTER_ENABLED=true
OPENROUTER_MODEL=openrouter/free
OPENROUTER_TIMEOUT_MS=90000
OPENROUTER_MAX_RETRIES=1
OPENROUTER_RATE_LIMIT_ABORT_AFTER=2
OPENROUTER_MAX_TOKENS=2500
OPENROUTER_MODEL_PRESENTATION=openai/o4-mini
OPENROUTER_MAX_TOKENS_PRESENTATION=8000
AI_TEXT_PROVIDER=openrouter
AI_IMAGE_PROVIDER=openrouter
AI_PRESENTATION_MODEL=
AI_IMAGE_MODEL=
AI_IMAGE_EDIT_MODEL=
OPENROUTER_FALLBACK_MODELS=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
DEEPSEEK_API_KEY=

# Image: local (default, без ключей) | external (OpenRouter + optional HF/Pollinations)
IMAGE_PROVIDER=local
IMAGE_FALLBACK_TO_LOCAL=true
AI_SKIP_OPENROUTER_IMAGE=false
AI_SKIP_POLLINATIONS=true
AI_SKIP_HUGGINGFACE=true
AI_NO_MOCKUP_FALLBACK=true
AI_POST_LOGO_COMPOSITE=true

# OpenRouter image generation
OPENROUTER_PREVIEW_ENABLED=true
OPENROUTER_IMAGE_MODEL_PREVIEW=black-forest-labs/flux.2-klein-4b
OPENROUTER_PREVIEW_ASPECT_RATIO=
OPENROUTER_PREVIEW_JPEG_QUALITY=85
OPENROUTER_IMAGE_MODEL_FINAL=google/gemini-2.5-flash-image
# Каталожный AI: Nano Banana Pro (финальная визуализация с multi-ref логотипом)
OPENROUTER_IMAGE_MODEL_CATALOG=google/gemini-3-pro-image-preview
OPENROUTER_REFINE_MODEL=
OPENROUTER_FINAL_ASPECT_RATIO=1:1
OPENROUTER_FINAL_IMAGE_SIZE=1K
OPENROUTER_CATALOG_ASPECT_RATIO=4:3
OPENROUTER_CATALOG_IMAGE_SIZE=1K
OPENROUTER_MAX_PRODUCT_REFS=6
OPENROUTER_PRODUCT_REF_MAX_PX=768
OPENROUTER_IMAGE_TIMEOUT_MS=240000
OPENROUTER_IMAGE_RETRIES=2

HUGGINGFACE_API_KEY=

MOCKUP_WIDTH=1024
MOCKUP_HEIGHT=1024
AI_ENHANCE_WIDTH=1024
AI_ENHANCE_HEIGHT=1024
