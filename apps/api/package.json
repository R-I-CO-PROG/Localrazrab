{
  "name": "@suvenir/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate --schema=../../prisma/schema.prisma && nest build",
    "dev": "nest start --watch",
    "postinstall": "prisma generate --schema=../../prisma/schema.prisma",
    "prestart": "prisma generate --schema=../../prisma/schema.prisma",
    "start": "node dist/src/main",
    "prisma:generate": "prisma generate --schema=../../prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "catalog:import": "tsx prisma/import-full-catalog.ts",
    "catalog:import-imba": "tsx prisma/import-imba-catalog.ts",
    "catalog:merge": "tsx prisma/merge-catalog-backup.ts",
    "smoke:openrouter": "tsx scripts/smoke-openrouter.ts",
    "test": "tsx --test src/concept/selection-constraints.spec.ts src/concept/product-role.spec.ts src/concept/catalog-pipeline.spec.ts src/concept/catalog-concept-discover.spec.ts src/concept/cross-concept-uniqueness.spec.ts src/requests/parse-brief.util.spec.ts src/requests/analyze-brief.util.spec.ts src/catalog/imba-category-overrides.spec.ts src/providers/llm/catalog-index.util.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.34.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^4.22.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "undici": "^6.27.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "@xenova/transformers": "^2.17.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
