# Server-side upstream (не NEXT_PUBLIC — не попадает в браузер)
SUVENIR_API_URL=http://localhost:3001
API_SECRET_KEY=

# Браузер ходит через BFF proxy
NEXT_PUBLIC_API_BASE=/api/backend
NEXT_PUBLIC_SITE_HOST=

# Better Auth + PostgreSQL (та же БД, что и на mercai.ru)
DATABASE_URL=postgresql://mertsai:password@127.0.0.1:5432/mertsai?schema=public
BETTER_AUTH_SECRET=change-me-min-32-characters-long-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Админ: email через запятую + секрет для API (опционально)
ADMIN_EMAILS=admin@example.com
ADMIN_SECRET=

# Email verification (опционально)
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
