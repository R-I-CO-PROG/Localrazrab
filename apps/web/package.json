{
  "name": "@suvenir/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3000",
    "dev:webpack": "next dev -p 3000",
    "build": "prisma generate && next build && node scripts/copy-standalone-assets.mjs",
    "logic:extract": "node ../../scripts/extract-logic-prompts.mjs",
    "start": "next start -p 3000",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
